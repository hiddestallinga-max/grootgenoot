# Kopieer dit bestand naar .env.local en vul je eigen waarden in.
# .env.local staat in .gitignore en komt NOOIT in git/GitHub.

# --- Supabase (Project Settings > API) ---
# Alleen server-side gebruikt, dus geen NEXT_PUBLIC_ nodig.
# (NEXT_PUBLIC_SUPABASE_URL werkt ook nog, voor bestaande omgevingen.)
SUPABASE_URL=https://JOUW-PROJECT.supabase.co

# Server-only! Nooit in de browser. Wordt gebruikt om aanmeldingen op te slaan
# en de regiekamer te vullen (omzeilt Row Level Security).
SUPABASE_SERVICE_ROLE_KEY=JOUW_SERVICE_ROLE_KEY

# --- Regiekamer (admin) ---
# Het wachtwoord waarmee jij inlogt op /admin. Kies iets langs en willekeurigs.
ADMIN_PASSWORD=kies-een-sterk-wachtwoord

# Een lange, willekeurige geheime string waarmee sessietokens worden ondertekend.
# Genereer er een met:  openssl rand -hex 32
ADMIN_SESSION_SECRET=plak-hier-een-lange-willekeurige-string

# --- E-mail (Resend) ---
# 1. Maak een gratis account op resend.com (3.000 mails/maand gratis)
# 2. Verifieer het domein grootgenoot.nl: voeg de DNS-records die Resend geeft
#    toe bij mijndomein.nl > DNS-beheer
# 3. Plak hier je API-key. Zolang dit leeg is, verstuurt de site simpelweg
#    geen mail (alles blijft verder gewoon werken).
RESEND_API_KEY=
EMAIL_VAN="Grootgenoot <info@grootgenoot.nl>"
EMAIL_NAAR=info@grootgenoot.nl

# --- Stripe (betalingen met automatische splitsing) ---
# Dashboard > Developers > API keys. Begin met de sk_test_ key (testmodus)!
STRIPE_SECRET_KEY=
# Dashboard > Developers > Webhooks > endpoint https://JOUW-DOMEIN/api/stripe/webhook
# events: account.updated, checkout.session.completed, payment_intent.succeeded, payment_intent.payment_failed
STRIPE_WEBHOOK_SECRET=
