# Kopieer dit bestand naar .env.local en vul je eigen Supabase-waarden in.
# .env.local staat in .gitignore en komt NOOIT in git/GitHub.

# Vind je in Supabase: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://JOUW-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=JOUW_ANON_KEY

# Alleen server-side gebruiken (nooit in de browser!). Voor het admin-overzicht later.
SUPABASE_SERVICE_ROLE_KEY=JOUW_SERVICE_ROLE_KEY
